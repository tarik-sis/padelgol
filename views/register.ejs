<%- include('partials/header') %>

<div class="auth-wrap">
  <form class="auth-card" method="post" action="/register">
    <h2>Create your account</h2>
    <% if (error) { %><p class="error"><%- error %></p><% } %>
    <label>Username<input name="username" required></label>
    <label>Email<input name="email" type="email"></label>
    <label>Password<input name="password" type="password" required></label>
    <label>Security question<input name="security_question" placeholder="e.g. First pet?"></label>
    <label>Security answer<input name="security_answer"></label>
    <!-- VULN: role field is accepted from the form (mass assignment) -->
    <input type="hidden" name="role" value="user">
    <button class="btn primary">Sign up</button>
  </form>
</div>

<%- include('partials/footer') %>
